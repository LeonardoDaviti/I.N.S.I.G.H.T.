TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_SESSION_FILE=insight_session

REDDIT_CLIENT_ID= 
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
REDDIT_USERNAME=
REDDIT_PASSWORD=

DB_USER=insight
DB_PASSWORD=insight
DB_NAME=insight
DB_HOST=localhost
DB_PORT=5432
POSTGRES_PORT=5432

# Admin Database (for creating database)
ADMIN_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Application Database (generated from above)
DATABASE_URL=postgresql://insight:insight@localhost:5432/insight

# Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_PORT=8000

# Frontend Configuration
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000

# Ingestion / Scheduling
SAFE_INGEST_SKIP_THRESHOLD_HOURS=12
INSIGHT_INGEST_INTERVAL_HOURS=12
INSIGHT_SYNC_SOURCES_EACH_CYCLE=true
INSIGHT_GENERATE_DAILY_BRIEFING=true
INSIGHT_GENERATE_TOPIC_BRIEFING=false
INSIGHT_SOURCES_JSON_PATH=backend/insight_core/config/sources.json

# Gemini model routing
GEMINI_MODEL=gemini-3.0-flash
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-flash-latest,gemini-2.0-flash
